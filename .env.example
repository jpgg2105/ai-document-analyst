# AI Document Analyst — Environment Configuration

# OpenAI API Key (required for LLM generation)
OPENAI_API_KEY=sk-your-key-here

# LLM Configuration
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# Embedding Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Qdrant Configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# Chunking Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval Configuration
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
